# =============================================================================
# correios-logistica-reversa — environment template
# =============================================================================
# Copy to .env for local development ONLY. Never commit .env.
#
# In a host application (NestJS, Next.js API, worker):
#   - Inject these as process.env via your secret manager / ConfigModule
#   - Call loadConfigFromEnv() AFTER env is populated
#   - The npm package does NOT load .env files automatically
#
# Full reference: docs/API.md § Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# production | homologation  (aliases: prod, homolog, development)
CORREIOS_ENV=production

# SOAP credentials from your Correios contract (SIGEP / Logística Reversa)
CORREIOS_USUARIO=
CORREIOS_SENHA=

# Contract identifiers (from correios_config or Correios portal)
CORREIOS_COD_ADMINISTRATIVO=
CORREIOS_CARTAO_POSTAGEM=
CORREIOS_NUMERO_CONTRATO=
CORREIOS_CNPJ=

# Reverse service code — CONTRACT-SPECIFIC (ask Correios / check your DB)
# Examples: 03301 (PAC reverso), 04677, 04170 (manual reference codes)
CORREIOS_CODIGO_SERVICO=

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------

# CORREIOS_WSDL_URL=          # override default WSDL per environment
# CORREIOS_TIMEOUT_MS=180000  # SOAP timeout (default 180s)
# CORREIOS_REJECT_UNAUTHORIZED=true

# -----------------------------------------------------------------------------
# HOMOLOGATION SANDBOX (public Correios manual — experiments only)
# -----------------------------------------------------------------------------
# CORREIOS_ENV=homologation
# CORREIOS_USUARIO=empresacws
# CORREIOS_SENHA=123456
# CORREIOS_COD_ADMINISTRATIVO=17000190
# CORREIOS_CARTAO_POSTAGEM=0067599079
# CORREIOS_NUMERO_CONTRATO=9992157880
# CORREIOS_CNPJ=34028316000103
# CORREIOS_CODIGO_SERVICO=04677

# -----------------------------------------------------------------------------
# Package repo only — opt-in live integration tests
# -----------------------------------------------------------------------------
# CORREIOS_LIVE_TEST=1