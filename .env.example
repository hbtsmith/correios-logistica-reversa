# Correios Logística Reversa — copy to .env (never commit .env)

# production | homologation
CORREIOS_ENV=homologation

# Contract credentials (from your Correios contract — NOT committed)
CORREIOS_USUARIO=
CORREIOS_SENHA=
CORREIOS_COD_ADMINISTRATIVO=
CORREIOS_CARTAO_POSTAGEM=
CORREIOS_NUMERO_CONTRATO=
CORREIOS_CNPJ=

# Service code: 04677 = PAC reverso, 04170 = SEDEX reverso
CORREIOS_CODIGO_SERVICO=04677

# Optional
# CORREIOS_WSDL_URL=
# CORREIOS_TIMEOUT_MS=180000
# CORREIOS_REJECT_UNAUTHORIZED=true

# Homologation sandbox (public Correios manual values — for local experiments only)
# CORREIOS_ENV=homologation
# CORREIOS_USUARIO=empresacws
# CORREIOS_SENHA=123456
# CORREIOS_COD_ADMINISTRATIVO=17000190
# CORREIOS_CARTAO_POSTAGEM=0067599079
# CORREIOS_NUMERO_CONTRATO=9992157880
# CORREIOS_CNPJ=34028316000103

# Opt-in live integration tests (pnpm test:live)
# CORREIOS_LIVE_TEST=1